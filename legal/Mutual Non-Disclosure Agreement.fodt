   <style:text-properties fo:font-variant="normal" fo:text-transform="none" fo:color="#000000" loext:opacity="100%" style:font-name="Arial" fo:font-size="15pt" fo:language="none" fo:country="none" fo:font-style="normal" fo:font-weight="bold" style:font-name-asian="Arial" style:font-size-asian="15pt" style:font-style-asian="normal" style:font-weight-asian="bold" style:font-name-complex="Arial" style:font-size-complex="15pt" style:language-complex="none" style:country-complex="none" style:font-style-complex="normal" style:font-weight-complex="bold"/>
